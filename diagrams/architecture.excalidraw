      "x": -125.30139822603721,
      "y": 197.80509737721815,
      "width": 1279.9989013671875,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b04",
      "roundness": null,
      "seed": 1118975855,
      "version": 1668,
      "versionNonce": 1068687471,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1770259045834,
      "link": null,
      "locked": false,
      "text": "Functional: \n1. Users should be able to add study spots\n2. Users should be able to check \"busyness\" of study spots \n3. Users should be able to evaluate \"busyness\" of study spots\n4. Users should be able to search for a study spot\n5. System should update \"busyness\" scores every 15 minutes\n6. System should display all study spots on the map\n7. System should display a ranking of study spots based on filters. These filters include distance, busyness score, overall ambiance\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional: \n1. Users should be able to add study spots\n2. Users should be able to check \"busyness\" of study spots \n3. Users should be able to evaluate \"busyness\" of study spots\n4. Users should be able to search for a study spot\n5. System should update \"busyness\" scores every 15 minutes\n6. System should display all study spots on the map\n7. System should display a ranking of study spots based on filters. These filters include distance, busyness score, overall ambiance\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
